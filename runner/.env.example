# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Sanity
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_WRITE_TOKEN=

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=

# Local paths
CORPUS_DIR=~/Documents/surviving-sogice-corpus
EXPORTS_DIR=~/Documents/surviving-sogice-exports

# Ollama (default: local)
# Run `ollama list` to see installed models and verify names match exactly.
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:4b

# Three-tier local model strategy (Codex recommendation):
#   local           → everyday multilingual + JSON reliability
#   local-heavy     → long books / SRTs / rich interpretive fields (risk: high RAM — defer until Streamlit RAM monitor built)
#   local-reasoning → ambiguous docs, confidence scoring, evidence extraction
#
# Verified Ollama names (run `ollama pull <name>` to install):
#   qwen3:8b                   — safe default, ~5 GB, good multilingual + JSON
#   gemma-4-26B-A4B-it         — heavy docs (verify RAM with Streamlit monitor first)
#   Ministral-3-14B-Reasoning-2512 — reasoning (verify exact name with `ollama list`)
LOCAL_ANALYSIS_MODEL=qwen3:8b
LOCAL_ANALYSIS_MODEL_HEAVY=gemma-4-26B-A4B-it
LOCAL_ANALYSIS_MODEL_REASONING=Ministral-3-14B-Reasoning-2512

# Claude model (update when Anthropic releases new versions)
CLAUDE_MODEL=claude-sonnet-4-6

# OpenRouter (free tier available — no credit card needed for free models)
# Get key at: https://openrouter.ai/keys
# Browse free models at: https://openrouter.ai/models?q=free
# The :free suffix selects the free preview tier of a model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Truncation limits (characters).
# TRUNCATION_LIMIT applies when --llm claude (API cost reason: default 24k).
# TRUNCATION_LIMIT_LOCAL applies when --llm local/prefer-local (gemma4 has
# 128k context; set high for full SRTs and books). Use a high value or remove
# the limit entirely via --max-chars 0 on the CLI.
TRUNCATION_LIMIT=24000
TRUNCATION_LIMIT_LOCAL=120000
